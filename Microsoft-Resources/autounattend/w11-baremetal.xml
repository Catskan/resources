<?xml version="1.0" encoding="utf-8"?>
<!--
  Autounattend.xml — bare-metal Aurel-Gaming install (Ryzen 9800X3D, Asus B850).

  Drop this file at the root of the Windows 11 USB install media (Rufus burns
  the Win11 ISO to USB → you copy this XML + the $OEM$ folder produced by
  build-autounattend.sh on top).

  What it automates:
    - Locale fr-FR + en-US UI
    - Skips all OOBE screens (EULA, OOBE wizard, wireless setup, online MS
      account requirement via BypassNRO registry key)
    - Creates local admin account "Aurel" with the password you typed at
      build time
    - AutoLogon for 5 reboots so FirstLogonCommands can complete
    - Bumps WinRM quotas
    - Downloads + runs ConfigureRemotingForAnsible.ps1 (HTTPS WinRM listener,
      self-signed cert, Basic auth, firewall rule)
    - Disables Tamper Protection (best-effort)
    - Installs ALL drivers under C:\Drivers\ via pnputil — that folder is
      populated by Setup from $OEM$\$1\Drivers\ on the USB (Asus B850 motherboard
      driver pack lands there)
    - Writes the DHCP-assigned IPv4 address to C:\Aurel-Gaming-IP.txt so you
      can read it from the screen and plug it into the Ansible inventory

  What it does NOT do (deliberate):
    - No <DiskConfiguration> → Setup stops on the partition selection screen so
      YOU choose the target NVMe by hand (safer on a system with existing M:\
      data drives that must not be wiped)
    - No Microsoft Account sign-in (web-based + 2FA, not scriptable — handled
      post-install by KeePassXC Auto-Type Ctrl+Shift+V on the Store login window)
    - No Ansible / git / Python install on this machine — keep it lean, Mac
      controller drives everything via WinRM

  Placeholder %%PASSWORD_BASE64%% is replaced by build-autounattend.sh with
  the MS-style encoded password: base64(UTF-16LE(password + "Password")).
-->
<unattend xmlns="urn:schemas-microsoft-com:unattend" xmlns:wcm="http://schemas.microsoft.com/WMIConfig/2002/State">

  <settings pass="windowsPE">
    <component name="Microsoft-Windows-International-Core-WinPE" processorArchitecture="amd64" publicKeyToken="31bf3856ad364e35" language="neutral" versionScope="nonSxS">
      <SetupUILanguage>
        <UILanguage>en-US</UILanguage>
      </SetupUILanguage>
      <InputLocale>040c:0000040c</InputLocale>
      <SystemLocale>fr-FR</SystemLocale>
      <UILanguage>en-US</UILanguage>
      <UserLocale>fr-FR</UserLocale>
    </component>

    <component name="Microsoft-Windows-Setup" processorArchitecture="amd64" publicKeyToken="31bf3856ad364e35" language="neutral" versionScope="nonSxS">
      <UserData>
        <ProductKey>
          <Key/>
          <WillShowUI>OnError</WillShowUI>
        </ProductKey>
        <AcceptEula>true</AcceptEula>
        <FullName>Aurel</FullName>
        <Organization>Local</Organization>
      </UserData>
    </component>
  </settings>

  <settings pass="specialize">
    <component name="Microsoft-Windows-Shell-Setup" processorArchitecture="amd64" publicKeyToken="31bf3856ad364e35" language="neutral" versionScope="nonSxS">
      <ComputerName>Aurel-Gaming</ComputerName>
      <TimeZone>Romance Standard Time</TimeZone>
    </component>
    <component name="Microsoft-Windows-Deployment" processorArchitecture="amd64" publicKeyToken="31bf3856ad364e35" language="neutral" versionScope="nonSxS">
      <RunSynchronous>
        <RunSynchronousCommand wcm:action="add">
          <Order>1</Order>
          <Description>Bypass Network Requirement (Win11 22H2+ otherwise demands net + MS account during OOBE)</Description>
          <Path>reg add "HKLM\SOFTWARE\Microsoft\Windows\CurrentVersion\OOBE" /v BypassNRO /t REG_DWORD /d 1 /f</Path>
        </RunSynchronousCommand>
      </RunSynchronous>
    </component>
  </settings>

  <settings pass="oobeSystem">
    <component name="Microsoft-Windows-International-Core" processorArchitecture="amd64" publicKeyToken="31bf3856ad364e35" language="neutral" versionScope="nonSxS">
      <InputLocale>040c:0000040c</InputLocale>
      <SystemLocale>fr-FR</SystemLocale>
      <UILanguage>en-US</UILanguage>
      <UserLocale>fr-FR</UserLocale>
    </component>

    <component name="Microsoft-Windows-Shell-Setup" processorArchitecture="amd64" publicKeyToken="31bf3856ad364e35" language="neutral" versionScope="nonSxS">
      <OOBE>
        <HideEULAPage>true</HideEULAPage>
        <HideLocalAccountScreen>true</HideLocalAccountScreen>
        <HideOnlineAccountScreens>true</HideOnlineAccountScreens>
        <HideWirelessSetupInOOBE>true</HideWirelessSetupInOOBE>
        <NetworkLocation>Home</NetworkLocation>
        <ProtectYourPC>3</ProtectYourPC>
        <SkipMachineOOBE>true</SkipMachineOOBE>
        <SkipUserOOBE>true</SkipUserOOBE>
      </OOBE>

      <UserAccounts>
        <LocalAccounts>
          <LocalAccount wcm:action="add">
            <Name>Aurel</Name>
            <Group>Administrators</Group>
            <Password>
              <Value>%%PASSWORD_BASE64%%</Value>
              <PlainText>false</PlainText>
            </Password>
            <DisplayName>Aurel</DisplayName>
          </LocalAccount>
        </LocalAccounts>
      </UserAccounts>

      <AutoLogon>
        <Username>Aurel</Username>
        <Password>
          <Value>%%PASSWORD_BASE64%%</Value>
          <PlainText>false</PlainText>
        </Password>
        <Enabled>true</Enabled>
        <LogonCount>5</LogonCount>
      </AutoLogon>

      <FirstLogonCommands>
        <SynchronousCommand wcm:action="add">
          <Order>1</Order>
          <Description>Install all INF drivers staged under C:\Drivers (from $OEM$\$1\Drivers on USB)</Description>
          <CommandLine>cmd.exe /c if exist C:\Drivers ( pnputil /add-driver C:\Drivers\*.inf /subdirs /install ) else ( echo No staged drivers folder, skipping )</CommandLine>
        </SynchronousCommand>

        <SynchronousCommand wcm:action="add">
          <Order>2</Order>
          <Description>Wait for network (drivers may have just brought the NIC up)</Description>
          <CommandLine>powershell.exe -ExecutionPolicy Bypass -Command "Start-Sleep -Seconds 20"</CommandLine>
        </SynchronousCommand>

        <SynchronousCommand wcm:action="add">
          <Order>3</Order>
          <Description>Set all network connections to Private (required for WinRM firewall rule)</Description>
          <CommandLine>powershell.exe -ExecutionPolicy Bypass -Command "Get-NetConnectionProfile | Set-NetConnectionProfile -NetworkCategory Private"</CommandLine>
        </SynchronousCommand>

        <SynchronousCommand wcm:action="add">
          <Order>4</Order>
          <Description>Download ConfigureRemotingForAnsible.ps1</Description>
          <CommandLine>powershell.exe -ExecutionPolicy Bypass -Command "Invoke-WebRequest -Uri 'https://raw.githubusercontent.com/ansible/ansible-documentation/devel/examples/scripts/ConfigureRemotingForAnsible.ps1' -OutFile C:\ConfigureRemotingForAnsible.ps1"</CommandLine>
        </SynchronousCommand>

        <SynchronousCommand wcm:action="add">
          <Order>5</Order>
          <Description>Run WinRM bootstrap (HTTPS listener + Basic auth + firewall rule)</Description>
          <CommandLine>powershell.exe -ExecutionPolicy Bypass -File C:\ConfigureRemotingForAnsible.ps1 -SkipNetworkProfileCheck</CommandLine>
        </SynchronousCommand>

        <SynchronousCommand wcm:action="add">
          <Order>6</Order>
          <Description>WinRM quota - global timeout</Description>
          <CommandLine>cmd.exe /c winrm set winrm/config "@{MaxTimeoutms=&quot;1800000&quot;}"</CommandLine>
        </SynchronousCommand>
        <SynchronousCommand wcm:action="add">
          <Order>7</Order>
          <Description>WinRM quota - concurrent ops per user</Description>
          <CommandLine>cmd.exe /c winrm set winrm/config/service "@{MaxConcurrentOperationsPerUser=&quot;4294967295&quot;}"</CommandLine>
        </SynchronousCommand>
        <SynchronousCommand wcm:action="add">
          <Order>8</Order>
          <Description>WinRM quota - memory per shell</Description>
          <CommandLine>cmd.exe /c winrm set winrm/config/winrs "@{MaxMemoryPerShellMB=&quot;2048&quot;}"</CommandLine>
        </SynchronousCommand>
        <SynchronousCommand wcm:action="add">
          <Order>9</Order>
          <Description>WinRM quota - shells per user</Description>
          <CommandLine>cmd.exe /c winrm set winrm/config/winrs "@{MaxShellsPerUser=&quot;100&quot;}"</CommandLine>
        </SynchronousCommand>
        <SynchronousCommand wcm:action="add">
          <Order>10</Order>
          <Description>WinRM quota - idle timeout</Description>
          <CommandLine>cmd.exe /c winrm set winrm/config/winrs "@{IdleTimeout=&quot;7200000&quot;}"</CommandLine>
        </SynchronousCommand>

        <SynchronousCommand wcm:action="add">
          <Order>11</Order>
          <Description>Disable Tamper Protection (best-effort — may need manual confirmation on 24H2+)</Description>
          <CommandLine>powershell.exe -ExecutionPolicy Bypass -Command "Set-MpPreference -DisableTamperProtection $true -ErrorAction SilentlyContinue"</CommandLine>
        </SynchronousCommand>

        <SynchronousCommand wcm:action="add">
          <Order>12</Order>
          <Description>Restart WinRM to apply all quota changes</Description>
          <CommandLine>powershell.exe -ExecutionPolicy Bypass -Command "Restart-Service WinRM"</CommandLine>
        </SynchronousCommand>

        <SynchronousCommand wcm:action="add">
          <Order>13</Order>
          <Description>Write the DHCP IPv4 address to C:\Aurel-Gaming-IP.txt for inventory update</Description>
          <CommandLine>powershell.exe -ExecutionPolicy Bypass -Command "Get-NetIPAddress -AddressFamily IPv4 | Where-Object PrefixOrigin -eq 'Dhcp' | Select-Object IPAddress, InterfaceAlias | Out-File C:\Aurel-Gaming-IP.txt"</CommandLine>
        </SynchronousCommand>
      </FirstLogonCommands>
    </component>
  </settings>

</unattend>
