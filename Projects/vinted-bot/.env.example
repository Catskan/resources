# ============================================
# vinted-bot — configuration
# ============================================
# Multi-compte : créer un fichier par compte (`.env.aurelien`, `.env.amandine`)
# référencé par `env_file:` dans docker-compose.yml. Aucun n'est committé.
# Pour mono-compte, copier vers `.env` (`cp .env.example .env`).

# --- Vinted ---
VINTED_BASE_URL=https://www.vinted.fr
VINTED_COOKIES_PATH=/app/data/cookies/vinted-cookies.json
# user_id Vinted (récupéré via scripts/test-cookies.py — il est stocké dans le JWT access_token_web)
VINTED_USER_ID=0
# User-Agent réaliste (à actualiser tous les ~6 mois) — quotes obligatoires car contient parenthèses/;
VINTED_USER_AGENT="Mozilla/5.0 (Macintosh; Intel Mac OS X 14_5) AppleWebKit/605.1.15 (KHTML, like Gecko) Version/17.5 Safari/605.1.15"

# --- Bumper : politique de republication ---
BUMP_MAX_PER_DAY=6
# 1h min : permet 2 bumps consécutifs au pic lunch (12h puis 13h)
BUMP_MIN_DELAY_HOURS=1
# 10h : ne force PAS de bump pendant la zone morte 14-18h (gap lunch → soirée)
BUMP_MAX_DELAY_HOURS=10
# Active uniquement sur les heures de pic (12-13 lunch, 19-22 soir)
# Les heures hors-pic ont weight=0 dans HOUR_WEIGHTS (cf scheduler.py)
BUMP_ACTIVE_HOURS_START=12
BUMP_ACTIVE_HOURS_END=23
BUMP_MIN_DAYS_BETWEEN_REBUMP=5
BUMP_OFF_DAYS_PER_WEEK=0
# Jitter aléatoire : DSM tire à HH:00 mais le bot attend N min avant d'agir
# (anti-pattern temporel, surtout utile en multi-compte)
BUMP_JITTER_MIN_MIN=0
BUMP_JITTER_MAX_MIN=45
# Sélection pondérée par saison :
#   off    = random uniforme (défaut, OK pour comptes non-vêtements)
#   auto   = utilise la saison du jour (été/hiver/printemps/automne)
#   summer/winter/spring/autumn = force une saison
# Effet : multiplie le poids des articles dont le titre matche les mots-clés saisonniers
BUMP_PREFER_SEASON=off

# --- Photos : transformations anti-perceptual-hash ---
# Params calibrés pour rester invisibles à l'œil nu MAIS casser le dHash 8-bit
# (distance Hamming > 5 sur 64 bits = considéré "différent" par les systèmes
# de dédup perceptual standard)
PHOTO_CROP_PX_MAX=8
PHOTO_ROTATION_MAX_DEG=0.6
PHOTO_JPEG_QUALITY_MIN=84
PHOTO_JPEG_QUALITY_MAX=92
PHOTO_NOISE_SIGMA=3.0
PHOTO_BRIGHTNESS_PCT_MAX=3.0

# --- LLM (LM Studio sur PC Windows) ---
LLM_BASE_URL=http://192.168.1.42:1234/v1
LLM_MODEL_ID=mistral-small
LLM_TIMEOUT_SEC=120
LLM_MAX_TOKENS=600
# bind address pour `lms server start --bind` : 0.0.0.0 = accessible depuis LAN (obligatoire pour le NAS)
LMS_BIND=0.0.0.0

# --- PC Windows : Wake-on-LAN + SSH ---
PC_MAC=AA:BB:CC:DD:EE:FF
PC_IP=192.168.1.42
PC_SSH_USER=aurelien
PC_SSH_KEY_PATH=/root/.ssh/id_ed25519
PC_BOOT_TIMEOUT_SEC=180
PC_LLM_READY_TIMEOUT_SEC=120

# --- Stockage ---
DB_PATH=/app/data/db/vinted-bot.sqlite
LOG_PATH=/app/data/logs
LOG_LEVEL=INFO

# --- Notifications ---
NOTIF_ENABLED=true
NOTIF_TYPE=email
NOTIF_EMAIL_TO=aurelien.busutil@majelanx.com
SMTP_HOST=localhost
SMTP_PORT=25

# --- Optimizer LLM (Mistral via LM Studio sur PC Windows) ---
# Opt-in par compte : true sur Amandine (vêtements → SEO Vinted utile),
# laisse false ou retire pour les comptes où le LLM apporte peu
OPTIMIZER_ENABLED=false
OPTIMIZER_BATCH_SIZE=20
OPTIMIZER_MIN_PRICE_EUR=15.0
# Délai mini entre 2 optimisations d'un même article (jours)
OPTIMIZER_MIN_DAYS_BETWEEN_OPTIMIZATIONS=90
OPTIMIZER_PROPOSALS_PATH=/app/data/proposals

# --- Crosspost ---
CROSSPOST_QUEUE_PATH=/app/data/crosspost/queue.json

# --- Home Assistant : pilotage prise Zigbee du PC LLM (optionnel) ---
# Si HA_URL vide, le module wol.py skip le control de prise et fait juste WoL+SSH.
# Cas d'usage : PC sur prise connectée, normalement en veille profonde (consommation 0W).
# Le bot allume la prise → WoL → boot Win11 → SSH → lance lms.exe → travail → shutdown → coupe prise.
# IMPORTANT : si la prise était DEJA allumée au démarrage du run, elle n'est PAS coupée à la fin
# (préservation d'état — utile si quelqu'un utilise le PC pour autre chose en parallèle).
HA_URL=http://192.168.1.6:8123
HA_TOKEN=your_long_lived_access_token_here
HA_PC_SWITCH_ENTITY=switch.prise_bureau_switch
HA_POST_SHUTDOWN_WAIT_SEC=45
