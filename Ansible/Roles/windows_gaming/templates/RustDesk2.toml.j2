# Auto-generated by Ansible role windows_gaming/rustdesk_setup.yml
# Edit group_vars/windows_hosts/main.yml (rustdesk_* vars) to customize.
# Manual edits will be overwritten on the next role run.
#
# This is RustDesk's mutable per-machine settings file. Stored alongside
# RustDesk.toml (immutable, machine ID + keys, NOT touched by Ansible)
# in %ProgramData%\RustDesk\config\ when running as a Windows service.

[options]
# Allow inbound direct LAN connections (no relay round-trip)
"direct-server" = "{{ 'Y' if rustdesk_direct_access else 'N' }}"

# Auth: only permanent password (set by `rustdesk --password` from
# KeePass), no time-limited one-time PINs, no manual click-to-accept.
"verification-method" = "use-permanent-password"
"approve-mode" = "password"

# LAN auto-discovery so the client can find Aurel-Gaming without IP entry
"enable-lan-discovery" = "{{ 'Y' if rustdesk_lan_discovery else 'N' }}"

# Telemetry off
"allow-auto-disconnect" = "N"
"disable-clipboard" = "N"
"disable-audio" = "N"
"enable-file-transfer" = "Y"

{% if rustdesk_whitelist | length > 0 %}
# Restrict inbound to specific IPs / CIDRs
"whitelist" = "{{ rustdesk_whitelist | join(',') }}"
{% endif %}
