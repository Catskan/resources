#!/bin/sh
# Alerte (journald) quand / dépasse le seuil, pour anticiper une saturation.
# Consulter : journalctl -t disk-alert
# Déposé par Ansible — rôle proxmox_claude_lxc (ne pas éditer à la main).
THRESHOLD=85
USE=$(df --output=pcent / | tail -1 | tr -dc '0-9')
if [ "${USE:-0}" -ge "$THRESHOLD" ]; then
    logger -t disk-alert "ALERTE: / a ${USE}% (seuil ${THRESHOLD}%) sur $(hostname)"
fi
