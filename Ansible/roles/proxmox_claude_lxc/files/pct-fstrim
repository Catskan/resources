#!/bin/sh
# Rend à l'hôte Proxmox l'espace libéré DANS les conteneurs LXC.
# Les rootfs .raw (storage 'dir' = /var/lib/vz/images) sont creux : supprimer un
# fichier dans le CT ne rétrécit PAS le .raw tant qu'un fstrim n'a pas "perforé"
# les blocs vides. Sans ça, pve-root gonfle jusqu'à saturation (vécu le 2026-07-13).
# Déposé par Ansible — rôle proxmox_claude_lxc (ne pas éditer à la main).
for id in $(pct list | awk 'NR>1 {print $1}'); do
    pct fstrim "$id" >/dev/null 2>&1
done
