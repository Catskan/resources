{
  "env": {
    "PATH": "$(PATH);C:\\Program Files (x86)\\Steam"
  },
  "apps": [
    {
      "name": "Desktop",
      "image-path": "desktop.png"
    }{% for app in sunshine_apps %},
    {
      "name": {{ app.name | to_json }},
      "cmd": {{ app.cmd | to_json }},
      "image-path": {{ (('C:\\ProgramData\\Sunshine\\assets\\' ~ (app.name | regex_replace('[^A-Za-z0-9]+', '_')) ~ '.png') if app.image_url is defined else (app.image_path | default(''))) | to_json }}
    }{% endfor %}
  ]
}
